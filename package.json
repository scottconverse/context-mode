{
  "name": "context-mode",
  "version": "1.6.1",
  "type": "module",
  "description": "Context window optimization for Cowork. Sandboxes tool output, compresses what returns with a self-learning 3-stage pipeline, and tracks session state — reducing context consumption by 30–60% in typical sessions, more in research-heavy ones, while preserving errors and session-relevant content verbatim.",
  "main": "server/index.js",
  "bin": {
    "context-mode": "install.js"
  },
  "scripts": {
    "start": "node server/index.js",
    "test": "node test-e2e.js && node test-adversarial.js",
    "setup": "node scripts/setup.js",
    "stamp": "node scripts/stamp-version.js",
    "gen-routing-table": "node scripts/gen-routing-table.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.6.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "docx": "^9.6.1",
    "md-to-pdf": "^5.2.5",
    "pdfkit": "^0.18.0"
  }
}
